# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

OPEN_ROUTER_API="YOUR_OPENROUTER_API_KEY"
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_SHEET_WEBHOOK_URL: The Google Apps Script deployment Web App URL used to push target leads.
# Configure this with your deployed Google Apps Script URL.
GOOGLE_SHEET_WEBHOOK_URL="https://script.google.com/macros/s/AKfycbw6lbtrtC76ZNph7dIsbS71YWQPkw_d8HqkVMYfXpYjhN74s9BAna_UtI1GteF4T-boGg/exec"



#https://script.google.com/macros/s/AKfycbzjIxpAke-aD0h-0Eq8O70xq7SPwpaBeyLNYu2_lod9v3rvjhFG-MUhMaO5ww7aFj7P/exec